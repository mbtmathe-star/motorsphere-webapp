rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.role in ['admin', 'super_admin'];
    }

    // Max 5MB, image content type only
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
          && request.resource.size < 5 * 1024 * 1024;
    }

    // Max 2MB for avatars
    function isValidAvatar() {
      return request.resource.contentType.matches('image/.*')
          && request.resource.size < 2 * 1024 * 1024;
    }

    // ─── Avatars ─────────────────────────────────────────────────────────────
    // Path: avatars/{userId}/avatar.webp

    match /avatars/{userId}/{allPaths=**} {
      allow read:   if true;                            // Public CDN — avatars are public
      allow write:  if isOwner(userId) && isValidAvatar();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ─── Vehicle images ───────────────────────────────────────────────────────
    // Path: vehicles/{userId}/{vehicleId}/{imageIndex}.webp
    // Max 20 images per vehicle — enforced in application logic

    match /vehicles/{userId}/{vehicleId}/{allPaths=**} {
      allow read:   if true;                            // Public CDN — listing images are public
      allow write:  if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ─── Parts images ─────────────────────────────────────────────────────────
    // Path: parts/{userId}/{partId}/{imageIndex}.webp
    // Max 10 images per parts listing — enforced in application logic

    match /parts/{userId}/{partId}/{allPaths=**} {
      allow read:   if true;
      allow write:  if isOwner(userId) && isValidImage();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ─── Admin documents ──────────────────────────────────────────────────────
    // Path: admin/**  — private, admin-only

    match /admin/{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
