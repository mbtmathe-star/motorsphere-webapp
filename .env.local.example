# ════════════════════════════════════════════════════════════════════════════
# MotorSphere — Local Development Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ════════════════════════════════════════════════════════════════════════════

# ─── Firebase Client Config (public) ────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your apps → Web app
# These values are safe to expose — they are embedded in the client bundle.
# They don't grant any access without valid Firebase Security Rules.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=     # Optional — for Firebase Analytics

# ─── Firebase Admin SDK (SERVER-SIDE ONLY) ──────────────────────────────────
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
# Download the JSON file and extract these three values.
# ⚠️ NEVER expose these to client-side code.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# The private key must be a single-line string with \n for newlines:
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Used by Cloud Functions for transactional emails.
RESEND_API_KEY=re_

# ─── App Config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ─── Firebase Emulators ──────────────────────────────────────────────────────
# Set to true to connect to local Firebase emulators instead of cloud Firebase.
# Set to false when testing against real staging Firebase project.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true

# ─── How to get Firebase credentials ─────────────────────────────────────────
#
# Client Config (NEXT_PUBLIC_*):
#   Firebase Console → [Select project] → Project Settings (⚙️ gear)
#   → General tab → "Your apps" → Web app (</>) → firebaseConfig
#
# Admin SDK Private Key:
#   Firebase Console → [Select project] → Project Settings (⚙️ gear)
#   → Service accounts tab → Firebase Admin SDK
#   → "Generate new private key" → download JSON
#   → Open JSON, copy: project_id → FIREBASE_ADMIN_PROJECT_ID
#                      client_email → FIREBASE_ADMIN_CLIENT_EMAIL
#                      private_key → FIREBASE_ADMIN_PRIVATE_KEY (as a quoted string)
#
# ─────────────────────────────────────────────────────────────────────────────
